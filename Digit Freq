int main() {

    /* Enter your code here. Read input from STDIN. Print output to STDOUT */   
    char *s = malloc(1000*sizeof(char));
    scanf("%[^\n]",s);
    int *freq = malloc(10*sizeof(int));
    for(int i=0;s[i]!='\0';i++)
    {
        if((s[i]>='0') && (s[i]<='9')) freq[s[i]-'0'] += 1;
    } 
    for (int i=0; i<10; i++) {
        printf("%d ",freq[i]);
    }
    return 0;
}
